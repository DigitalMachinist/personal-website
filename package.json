{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npx astro dev",
    "build": "npm run build:content && npm run build:resume",
    "build:content": "npx astro build",
    "build:resume": "node scripts/generate-pdf.mjs",
    "preview": "npx astro preview",
    "astro": "npx astro",
    "generate:pdf": "node scripts/generate-pdf.mjs",
    "deploy": "npm run build && npx wrangler pages deploy"
  },
  "dependencies": {
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "wrangler": "^4.75.0"
  }
}
