<button
  class="theme-toggle"
  id="themeToggle"
  aria-label="Switch to light theme"
  type="button"
>
  <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  const root = document.documentElement;
  const toggle = document.getElementById('themeToggle')!;
  const STORAGE_KEY = 'dm-theme';

  // Sync aria-label with saved theme (already applied to <html> by anti-flash script)
  const initialTheme = root.getAttribute('data-theme') || 'dark';
  toggle.setAttribute(
    'aria-label',
    initialTheme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'
  );

  function setTheme(theme: string) {
    root.setAttribute('data-theme', theme);
    localStorage.setItem(STORAGE_KEY, theme);
    toggle.setAttribute(
      'aria-label',
      theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'
    );
  }

  toggle.addEventListener('click', () => {
    const current = root.getAttribute('data-theme') || 'dark';
    setTheme(current === 'dark' ? 'light' : 'dark');
  });
</script>

<style>
  .theme-toggle {
    width: 44px;
    height: 44px;
    border: 1px solid var(--card-border);
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .theme-toggle svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .theme-toggle .icon-moon {
    display: none;
  }

  :global([data-theme="light"]) .theme-toggle .icon-sun {
    display: none;
  }

  :global([data-theme="light"]) .theme-toggle .icon-moon {
    display: block;
  }
</style>
